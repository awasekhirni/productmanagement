# DOC_ADR_v1.0.toon
# CMMI Level 5 Compliant Architecture Decision Record Generator

IMPORT:CMMI_LEVEL5_BASE_TEMPLATE.toon

ROLE:principal_architect|systems_engineer|security_architect|compliance_engineer
TASK:generate_cmmi_l5_compliant_adr_with_quantitative_impact_analysis_and_pdf_report
OUTPUT_FORMAT:Markdown_source + PDF/A-3_report + machine_readable_json_for_architecture_repository

INPUT_CONTEXT{
  decision{
    id:STR|format:ADR-###|auto_increment_from_repository
    title:STR|required|concise_decision_statement
    status:ENUM:[proposed,accepted,deprecated,superseded]|default:proposed
    date:DATE|default:current_date
    superseded_by:STR|optional|link_to_new_adr_if_deprecated
  }
  context{
    problem_statement:STR|required|business_or_technical_problem_being_solved
    constraints:ARR|EXAMPLE:[budget_timeline_tech_stack_compliance_requirements]
    stakeholders:ARR|roles_affected_by_this_decision
    related_docs:ARR|links_to_prd_requirements_compliance_docs_other_adrs
  }
  options_considered:ARR|min_items:2|structure:{
    option_id:STR|EXAMPLE:[opt_a_opt_b_opt_c]
    description:STR|detailed_explanation_of_approach
    pros:ARR|benefits_and_advantages
    cons:ARR|drawbacks_and_risks
    quantitative_analysis:OBJECT|optional|{
      cost_estimate:NUM|currency_or_effort_units
      performance_impact:STR|EXAMPLE:"p95_latency_increase_15_percent"
      scalability_projection:STR|EXAMPLE:"supports_10x_load_with_linear_cost"
      compliance_impact:STR|EXAMPLE:"simplifies_gdpr_data_residency_compliance"
    }
  }
  decision{
    selected_option:STR|reference_to_options_considered.option_id
    rationale:STR|required|detailed_justification_including_trade_offs
    quantitative_justification:OBJECT|optional|{
      cost_benefit_ratio:NUM|if_applicable
      risk_score_comparison:OBJECT|option_id:risk_score_1_to_10
      compliance_coverage_improvement:STR|percentage_or_qualitative_assessment
    }
  }
  consequences{
    positive:ARR|expected_benefits_and_outcomes
    negative:ARR|accepted_trade_offs_and_mitigation_plans
    compliance_impact:STR|how_decision_affects_regulatory_compliance_posture
    technical_debt:STR|any_debt_incurred_with_repayment_plan_if_applicable
  }
  implementation{
    action_items:ARR|structure:{task:STR,owner:STR,due_date:DATE,priority:ENUM}
    validation_approach:STR|how_decision_success_will_be_measured
    monitoring_metrics:ARR|quantitative_indicators_to_track_post_implementation
    review_schedule:DATE|when_decision_will_be_re_evaluated
  }
}

CMMI_L5_ENHANCEMENTS{
  quantitative_decision_analysis{
    decision_quality_metrics{
      options_evaluated_completeness:count_of_viable_options_considered|target:≥3
      quantitative_analysis_depth:percentage_of_options_with_numerical_impact_estimates|target:≥80%
      stakeholder_consensus_score:rating_from_reviewers_1_to_5|target:≥4.0
    }
    statistical_process_control{
      decision_cycle_time:days_from_proposal_to_acceptance|control_limits:[2,10]|Cpk_target:≥1.33
      decision_reversal_rate:percentage_of_adrs_deprecated_within_12_months|target:<5%
      post_implementation_success_rate:percentage_of_decisions_meeting_quantitative_targets|target:≥90%
    }
  }
  process_performance_objectives{
    adr_approval_cycle_time:target:≤7_business_days|UCL:12|LCL:3|Cpk:≥1.0
    decision_stability:target:≤10%_of_adrs_revised_post_approval|measured_quarterly
    compliance_alignment:target:100%_of_decisions_validated_against_applicable_frameworks
  }
  causal_analysis_integration{
    trigger:decision_reversed_or_post_implementation_failure_traced_to_adr
    analysis_method:5_whys + decision_traceability_audit + stakeholder_feedback_analysis
    preventive_action:auto_enhance_adr_template_with_additional_validation_criteria
  }
  innovation_deployment{
    ai_assisted_option_generation:pilot_nlp_model_to_identify_architecture_patterns|measure_quality
    automated_impact_estimation:integrate_with_cloud_cost_api_performance_testing_tools
  }
}

DOCUMENT_STRUCTURE{
  section_1{
    title:"ADR Metadata & Control"
    content:[decision_id,title,status,date,approvers,classification]
    pdf_formatting:header_table_with_digital_signature_fields_for_approvers
    cmmi_traceability:link_to_architecture_process_definition_and_metrics_repository
  }
  section_2{
    title:"Context & Problem Statement"
    content:[business_driver,technical_challenge,constraints,stakeholder_impact]
    visualizations:context_diagram_mermaid|stakeholder_matrix_table
    quantitative_context:baseline_metrics_that_motivate_the_decision
  }
  section_3{
    title:"Options Considered"
    content:iterate_over_input.options_considered
    format_per_option{
      header:"Option {option_id}: {description_summary}"
      detailed_description:technical_approach_with_architecture_diagram_if_applicable
      pros_cons_table:balanced_assessment_with_quantitative_data_where_available
      quantitative_analysis_section:cost_performance_scalability_compliance_impact_with_numbers
    }
    comparison_matrix:table_with_options_as_rows_and_criteria_as_columns_with_scores
  }
  section_4{
    title:"Decision & Rationale"
    content:[selected_option,detailed_rationale,trade_off_analysis]
    quantitative_justification:cost_benefit_analysis_risk_score_comparison_compliance_coverage
    decision_visualization:mermaid_decision_tree_or_weighted_scoring_diagram
  }
  section_5{
    title:"Consequences & Impact Analysis"
    content:[positive_outcomes,accepted_trade_offs,compliance_impact,technical_debt]
    quantitative_impact:projected_metrics_changes_with_confidence_intervals_if_applicable
    risk_assessment:updated_risk_register_with_mitigation_plans_for_negative_consequences
    compliance_mapping:explicit_links_to_regulatory_requirements_affected_by_decision
  }
  section_6{
    title:"Implementation & Validation Plan"
    content:iterate_over_input.implementation.action_items
    format_per_action{
      task_description:detailed_work_item_with_acceptance_criteria
      owner_assignment:role_or_individual_responsible
      timeline:due_date_with_dependencies_called_out
      success_metrics:quantitative_indicators_to_validate_completion
    }
    validation_approach:how_decision_success_will_be_measured_post_implementation
    monitoring_plan:metrics_to_track_with_dashboards_and_alerting_thresholds
  }
  section_7{
    title:"Review Schedule & Continuous Improvement"
    content:[next_review_date,success_criteria_for_re_evaluation,improvement_feedback_loop]
    cmmi_car_integration:how_this_adr_will_contribute_to_organizational_learning
    innovation_opportunities:areas_where_this_decision_enables_future_improvements
  }
  section_8{
    title:"Approval & Sign-off"
    content:[approval_criteria,reviewer_roles,signature_blocks]
    digital_signature_fields:PAdES_compliant_with_timestamp_and_audit_trail
    version_control:pdf_generated_with_git_commit_hash_and_decision_id_in_metadata
  }
}

QUANTITATIVE_METRICS_COLLECTION{
  decision_level_metrics{
    options_analysis_completeness:count_and_diversity_of_options_evaluated
    quantitative_rigor_score:percentage_of_options_with_numerical_impact_estimates
    stakeholder_consensus_index:agreement_level_from_reviewers_measured_via_survey
  }
  document_level_metrics{
    clarity_index:readability_score + peer_review_rating_for_understandability
    traceability_completeness:bidirectional_links_to_requirements_tests_compliance_controls
    compliance_coverage:percentage_of_applicable_regulatory_frameworks_addressed
  }
  process_metrics{
    decision_cycle_time:business_days_from_proposal_to_final_approval
    decision_stability:percentage_of_adrs_not_revised_within_12_months_of_approval
    post_implementation_success:percentage_of_decisions_meeting_quantitative_targets
  }
  metric_storage_and_analysis{
    repository:architecture_decision_repository_with_time_series_metrics
    dashboards:real_time_views_of_decision_quality_process_performance_outcomes
    statistical_analysis:control_charts_for_cycle_time_regression_for_success_predictors
  }
}

PDF_REPORT_SPECIFICATIONS{
  template:adr_enterprise_template_with_architecture_branding_and_cmmi_headers
  dynamic_content{
    options_comparison_table:auto_formatted_with_color_coding_by_score
    decision_visualization:mermaid_decision_tree_rendered_to_vector_graphics
    metrics_charts:quantitative_impact_projections_as_embedded_charts
    compliance_mapping:interactive_table_with_regulation_links_in_pdf
  }
  navigation_and_interactivity{
    pdf_bookmarks:hierarchical_structure_matching_adr_sections
    hyperlinks:cross_references_to_requirements_tests_compliance_docs_other_adrs
    form_fields:approval_signature_blocks_with_validation_timestamp_and_role
  }
  archival_and_compliance{
    pdf_a3:true_with_embedded_fonts_color_profiles_and_long_term_validation_metadata
    metadata:xmp_with_cmmi_process_tags_decision_id_compliance_mappings_metrics_snapshot
    accessibility:pdf_ua_compliant_with_tagged_structure_for_screen_reader_navigation
  }
  distribution_control{
    access_permissions:role_based_viewing_for_architects_engineers_compliance_auditors
    watermarking:draft_approved_deprecated_based_on_decision_status
    expiration:optional_time_limited_access_for_external_architecture_reviewers
    audit_logging:track_pdf_access_download_printing_with_user_and_system_context
  }
}

REVIEW_APPROVAL_WORKFLOW_CMMI_L5{
  stage_1_authoring{
    author_actions:populate_adr_template_with_quantitative_analysis_and_trade_offs
    automated_validation:required_fields_present|options_analyzed|metrics_defined
    quality_gates:minimum_options_evaluated|quantitative_analysis_threshold_met
    exit_criteria:complete_analysis_ready_for_architecture_review_board
  }
  stage_2_architecture_review{
    reviewers:[principal_architects,security_architect,compliance_engineer,tech_leads]
    review_method:structured_rubric_with_quantitative_scoring_for_each_decision_criteria
    defect_classification:technical_flaws_missing_analysis_stakeholder_gaps
    statistical_control:review_defect_density_and_consensus_score_monitored_via_spc
    exit_criteria:consensus_score_threshold_met|all_critical_defects_resolved
  }
  stage_3_compliance_validation{
    reviewer:compliance_officer_or_security_architect
    focus_areas:regulatory_impact_accuracy|risk_mitigation_adequacy|audit_trail_completeness
    approval_gate:compliance_signoff_required_for_decisions_affecting_regulated_data
    quantitative_check:100%_of_applicable_compliance_frameworks_assessed_and_documented
  }
  stage_4_final_approval{
    approvers:[cto,chief_architect,compliance_officer]
    digital_signature:PAdES_LTVA_compliant_for_long_term_archival_with_timestamp
    audit_trail:immutable_log_of_approval_events_with_decision_context_and_metrics
    version_control:pdf_filename_includes_adr_id_version_hash_and_approval_timestamp
  }
  continuous_improvement_loop{
    post_implementation_review:quantitative_analysis_of_decision_outcomes_vs_projections
    process_adjustments:auto_update_adr_template_or_review_criteria_based_on_outcome_data
    knowledge_base_update:store_approved_adr_patterns_and_decision_rationale_for_reuse
    innovation_deployment:pilot_ai_assisted_impact_estimation_if_accuracy_metrics_improve
  }
}

OUTPUT_GENERATION{
  primary_outputs{
    pdf_report{
      format:PDF/A-3_with_embedded_source_metadata_and_long_term_validation_support
      filename:"{product_name}_ADR-{decision_id}_v{version}_{YYYYMMDD}_CMMI_L5.pdf"
      delivery:secure_download + architecture_repository_index + email_notification
    }
    machine_readable_export{
      format:JSON_schema_validated_against_adr_schema_with_cmmi_extensions
      content:all_decision_data_metrics_traceability_in_structured_format
      use_case:architecture_knowledge_graph|automated_compliance_auditing|impact_analysis
    }
  }
  supplementary_outputs{
    executive_decision_summary:one_page_pdf_for_leadership_with_key_trade_offs_and_recommendation
    implementation_checklist:CSV_export_of_action_items_for_import_to_jira_or_azure_devops
    compliance_evidence_snippet:section_of_pdf_with_regulatory_mappings_for_audit_packages
    architecture_diagram_assets:high_res_png_svg_exports_of_mermaid_diagrams_for_presentations
  }
  metadata_and_audit{
    pdf_properties:title_author_subject_keywords_with_cmmi_architecture_compliance_tags
    custom_xmp_properties:process_version_decision_metrics_snapshot_approval_hash_git_commit
    audit_trail:immutable_log_of_pdf_generation_approval_and_access_events
  }
}

FOLLOW_UP_COMMANDS{
  generate_implementation_tasks:"Convert ADR action items to Jira tickets with labels and dependencies"
  create_compliance_evidence_snippet:"Extract regulatory mapping section for audit documentation bundle"
  schedule_outcome_review:"Set calendar reminder for post-implementation review per CMMI CAR process"
  update_architecture_knowledge_graph:"Ingest ADR JSON export into architecture repository for querying"
  initiate_causal_analysis:"If decision outcomes miss targets, trigger CAR process with quantitative data"
  generate_stakeholder_brief:"Create one-page summary from Sections 1,4,5 for non-technical leadership"
}
